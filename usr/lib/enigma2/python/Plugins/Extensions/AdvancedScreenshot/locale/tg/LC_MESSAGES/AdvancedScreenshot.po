msgstr "Истифода аз андозаи дукубӣ (тасвири сусттар, вале ҳамвортар)"

msgid "Video Only"
msgstr "Танҳо видео"

msgid "View captured screenshots"
msgstr "Намоиши скриншотҳои гирифташуда"

msgid "Web capture failed: Grab not available"
msgstr "Гирифтани веб ноком шуд: Гирифтан дастрас нест"

msgid "long ' can be used."
msgstr "дароз ' истифода бурдан мумкин аст."

msgid "long:"
msgstr "дароз:"

msgid "no message"
msgstr "хабар нест"

msgid "no timeout"
msgstr "танаффус нест"

msgid "please wait, loading picture..."
msgstr "лутфан интизор шавед, тасвир бор карда мешавад..."
