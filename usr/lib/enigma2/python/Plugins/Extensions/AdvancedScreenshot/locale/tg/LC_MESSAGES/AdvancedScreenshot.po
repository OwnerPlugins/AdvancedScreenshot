msgid "' button instead of '"
msgstr "тугмаи 'ба ҷои'"

msgid "Add -n option to force no stretching."
msgstr "Иловаи -n хосият барои маҷбур кардани дароз кардан."

msgid "Add letterbox if source is 16:9."
msgstr "Қуттии мактубро илова кунед, агар манбаъ 16:9 бошад."

