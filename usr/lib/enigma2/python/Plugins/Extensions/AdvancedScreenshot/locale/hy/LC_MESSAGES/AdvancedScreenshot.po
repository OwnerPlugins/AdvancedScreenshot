msgid "' button instead of '"
msgstr "կոճակի փոխարեն"

msgid "Add -n option to force no stretching."
msgstr "Ավելացնել -n տարբերակ՝ ստիպելու չձգվել:"

msgid "Add letterbox if source is 16:9."
msgstr "Ավելացնել փոստարկղ, եթե աղբյուրը 16:9 է:"

msgid "Advanced Screenshot"
msgstr "Ընդլայնված սքրինշոթ"

msgid "Advanced Screenshot Gallery"
msgstr "Ընդլայնված Սքրինշոթ պատկերասրահ"

msgid "Advanced Screenshot Setup"
msgstr "Սքրինշոթի առաջադեմ կարգավորում"

msgid "Always output 4:3 image"
msgstr "Միշտ թողարկեք 4:3 պատկեր"

msgid "Always output 4:3 image (adds letterbox if source is 16:9)"
msgstr "Միշտ թողարկեք 4:3 պատկեր (ավելացնում է փոստարկղը, եթե աղբյուրը 16:9 է)"

msgid "Always save screenshots"
msgstr "Միշտ պահեք սքրինշոթները"

msgid "Are you sure you want to delete this screenshot?"
msgstr "Իսկապե՞ս ուզում եք ջնջել այս սքրինշոթը:"

msgid "BMP"
msgstr ""

msgid "Choose which button triggers screenshot."
msgstr "Ընտրեք, թե որ կոճակն է գործարկում սքրինշոթը:"

msgid "Default Resolution"
msgstr "Կանխադրված լուծում"

msgid "Delete failed:"
msgstr "Չհաջողվեց ջնջել."

msgid "Enable or disable the Advanced Screenshot plugin."
msgstr "Միացնել կամ անջատել Advanced Screenshot plugin-ը:"

msgid "Enable plugin"
msgstr "Միացնել փլագինը"

msgid "Error during capture:\n"
msgstr "Սխալ նկարահանման ժամանակ՝\n"

msgid "Error loading gallery:"
msgstr "Սխալ՝ պատկերասրահը բեռնելիս."

msgid "Fix aspect ratio"
msgstr "Ուղղել կողմի հարաբերակցությունը"

msgid "Fix aspect ratio (adds -n to force no stretching)"
msgstr "Ուղղել կողմի հարաբերակցությունը (ավելացնում է -n, որպեսզի չձգվի)"

msgid "Folder where screenshots are saved."
msgstr "Թղթապանակ, որտեղ պահվում են սքրինշոթները:"

msgid "Freeze frame preview"
msgstr "Սառեցնել շրջանակի նախադիտումը"

msgid "Freeze the frame preview when taking screenshot."
msgstr "Սքրինշոթ անելիս սառեցրեք շրջանակի նախադիտումը:"

msgid "Hard Disk"
msgstr "Կոշտ սկավառակ"

msgid "Image format"
msgstr "Պատկերի ձևաչափ"

msgid "JPEG 100%"
msgstr ""

msgid "JPEG 60%"
msgstr ""

msgid "JPEG 80%"
msgstr ""

msgid "JPEG 90%"
msgstr ""

msgid "Long press must be used for this button."
msgstr "Այս կոճակի համար պետք է երկար սեղմել:"

msgid "Long press required for"
msgstr "համար պահանջվում է երկար սեղմում"

msgid "Long press required for button"
msgstr "Կոճակի համար պահանջվում է երկար սեղմում"

msgid "Message timeout (seconds)"
msgstr "Հաղորդագրության ժամկետը սպառվել է (վայրկյաններ)"

msgid "Network mount"
msgstr "Ցանցի ամրացում"

msgid "OSD + Video"
msgstr "OSD + Տեսանյութ"

msgid "OSD Only"
msgstr "Միայն OSD"

msgid "PNG"
msgstr ""

msgid "Press OK to save - EXIT to cancel"
msgstr "Պահելու համար սեղմեք OK - չեղարկելու համար EXIT"

msgid "Press type for"
msgstr "Սեղմեք տեսակը համար"

msgid "Press type for button"
msgstr "Սեղմեք տեսակը կոճակի համար"

msgid "Professional screenshot tool"
msgstr "Պրոֆեսիոնալ սքրինշոթ գործիք"

msgid "Resolution"
msgstr "Բանաձեւ"

msgid "Save path (requires restart)"
msgstr "Պահպանել ուղին (պահանջում է վերագործարկում)"

msgid "Save screenshots even if frame is frozen."
msgstr "Պահպանեք սքրինշոթները, նույնիսկ եթե շրջանակը սառեցված է:"

msgid "Screenshot saved successfully!"
msgstr "Սքրինշոթը հաջողությամբ պահպանվեց:"

msgid "Select screenshot button"
msgstr "Ընտրեք սքրինշոթ կոճակը"

msgid "Select the image format for screenshots."
msgstr "Ընտրեք պատկերի ձևաչափը սքրինշոթերի համար:"

msgid "Select the resolution for screenshots."
msgstr "Ընտրեք սքրինշոթերի լուծումը:"

msgid "Set press type for button instead of long press."
msgstr "Երկար սեղմելու փոխարեն սահմանեք սեղմման տեսակը կոճակի համար:"

msgid "Settings"
msgstr "Կարգավորումներ"

msgid "Slower but smoother image resizing."
msgstr "Ավելի դանդաղ, բայց ավելի հարթ պատկերի չափափոխում:"

msgid "Temporary"
msgstr "Ժամանակավոր"

msgid "Time to display messages on screen."
msgstr "Ժամանակն է ցուցադրել հաղորդագրությունները էկրանին:"

msgid "USB Drive"
msgstr "USB կրիչ"

msgid "Unknown"
msgstr "Անհայտ"

msgid "Use bicubic resize"
msgstr "Օգտագործեք bicubic չափափոխել"

msgid "Use bicubic resize (slower, but smoother image)"
msgstr "Օգտագործեք երկխորանարդ չափը (ավելի դանդաղ, բայց ավելի հարթ պատկեր)"

msgid "Video Only"
msgstr "Տեսանյութ Միայն"

msgid "View captured screenshots"
msgstr "Դիտեք նկարահանված սքրինշոթները"

msgid "Web capture failed: Grab not available"
msgstr "Վեբ նկարահանումը ձախողվեց. Grab-ը հասանելի չէ"

msgid "long ' can be used."
msgstr "երկար» կարող է օգտագործվել:"

msgid "long:"
msgstr "երկար:"

msgid "no message"
msgstr "ոչ մի հաղորդագրություն"

msgid "no timeout"
msgstr "ոչ մի թայմաութ"

msgid "please wait, loading picture..."
msgstr "խնդրում ենք սպասել, նկարը բեռնվում է..."
