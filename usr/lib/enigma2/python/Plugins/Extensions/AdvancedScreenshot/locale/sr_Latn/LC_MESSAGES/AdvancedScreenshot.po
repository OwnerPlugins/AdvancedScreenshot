msgstr "Користите бикубичну промену величине (спорија, али глаткија слика)"

msgid "Video Only"
msgstr "Само видео"

msgid "View captured screenshots"
msgstr "Погледајте снимљене снимке екрана"

msgid "Web capture failed: Grab not available"
msgstr "Веб снимање није успело: Граб није доступан"

msgid "long ' can be used."
msgstr "дуго ' може се користити."

msgid "long:"
msgstr "дуго:"

msgid "no message"
msgstr "нема поруке"

msgid "no timeout"
msgstr "нема временског ограничења"

msgid "please wait, loading picture..."
msgstr "сачекајте, слика се учитава..."
