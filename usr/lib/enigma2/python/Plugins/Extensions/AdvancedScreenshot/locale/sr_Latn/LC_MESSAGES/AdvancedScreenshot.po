msgid "Always output 4:3 image"
msgstr "Увек емитујте слику 4:3"

msgid "Always output 4:3 image (adds letterbox if source is 16:9)"
msgstr "Увек емитујте слику 4:3 (додаје поштанско сандуче ако је извор 16:9)"

