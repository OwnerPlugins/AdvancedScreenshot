msgid "' button instead of '"
msgstr "'பொத்தான்' என்பதற்குப் பதிலாக"

msgid "Add -n option to force no stretching."
msgstr "நீட்டிக்க வேண்டாம் என்று கட்டாயப்படுத்த -n விருப்பத்தைச் சேர்க்கவும்."

msgid "Add letterbox if source is 16:9."
msgstr "மூல 16:9 எனில் லெட்டர்பாக்ஸைச் சேர்க்கவும்."

msgid "Advanced Screenshot"
msgstr "மேம்பட்ட ஸ்கிரீன்ஷாட்"

msgid "Advanced Screenshot Gallery"
msgstr "மேம்பட்ட ஸ்கிரீன்ஷாட் தொகுப்பு"

msgid "Advanced Screenshot Setup"
msgstr "மேம்பட்ட ஸ்கிரீன்ஷாட் அமைப்பு"

msgid "Always output 4:3 image"
msgstr "எப்போதும் 4:3 படத்தை வெளியிடவும்"

msgid "Always output 4:3 image (adds letterbox if source is 16:9)"
msgstr "எப்போதும் 4:3 படத்தை வெளியிடவும் (மூலமாக 16:9 இருந்தால் லெட்டர்பாக்ஸைச் சேர்க்கும்)"

msgid "Always save screenshots"
msgstr "ஸ்கிரீன் ஷாட்களை எப்போதும் சேமிக்கவும்"

msgid "Are you sure you want to delete this screenshot?"
msgstr "இந்த ஸ்கிரீன்ஷாட்டை நிச்சயமாக நீக்க விரும்புகிறீர்களா?"

msgid "BMP"
msgstr ""

msgid "Choose which button triggers screenshot."
msgstr "எந்த பொத்தான் ஸ்கிரீன்ஷாட்டைத் தூண்டுகிறது என்பதைத் தேர்ந்தெடுக்கவும்."

msgid "Default Resolution"
msgstr "இயல்புநிலை தீர்மானம்"

msgid "Delete failed:"
msgstr "நீக்குவதில் தோல்வி:"

msgid "Enable or disable the Advanced Screenshot plugin."
msgstr "மேம்பட்ட ஸ்கிரீன்ஷாட் செருகுநிரலை இயக்கவும் அல்லது முடக்கவும்."

msgid "Enable plugin"
msgstr "செருகுநிரலை இயக்கு"

msgid "Error during capture:\n"
msgstr "பிடிக்கும்போது பிழை:\n"

msgid "Error loading gallery:"
msgstr "கேலரியை ஏற்றுவதில் பிழை:"

msgid "Fix aspect ratio"
msgstr "விகிதத்தை சரிசெய்யவும்"

msgid "Fix aspect ratio (adds -n to force no stretching)"
msgstr "விகிதத்தை சரிசெய்யவும் (நீட்டாமல் இருக்க கட்டாயப்படுத்த -n சேர்க்கிறது)"

msgid "Folder where screenshots are saved."
msgstr "ஸ்கிரீன் ஷாட்கள் சேமிக்கப்பட்ட கோப்புறை."

msgid "Freeze frame preview"
msgstr "ஃப்ரேஸ் ஃப்ரேம் மாதிரிக்காட்சி"

msgid "Freeze the frame preview when taking screenshot."
msgstr "ஸ்கிரீன்ஷாட் எடுக்கும்போது சட்ட முன்னோட்டத்தை முடக்கவும்."

msgid "Hard Disk"
msgstr "ஹார்ட் டிஸ்க்"

msgid "Image format"
msgstr "பட வடிவம்"

msgid "JPEG 100%"
msgstr ""

msgid "JPEG 60%"
msgstr ""

msgid "JPEG 80%"
msgstr ""

msgid "JPEG 90%"
msgstr ""

msgid "Long press must be used for this button."
msgstr "இந்த பட்டனை நீண்ட நேரம் அழுத்த வேண்டும்."

msgid "Long press required for"
msgstr "நீண்ட நேரம் அழுத்தவும்"

msgid "Long press required for button"
msgstr "பொத்தானை நீண்ட நேரம் அழுத்தவும்"

msgid "Message timeout (seconds)"
msgstr "செய்தி நேரம் முடிந்தது (வினாடிகள்)"

msgid "Network mount"
msgstr "நெட்வொர்க் மவுண்ட்"

msgid "OSD + Video"
msgstr "OSD + வீடியோ"

msgid "OSD Only"
msgstr "OSD மட்டும்"

msgid "PNG"
msgstr ""

msgid "Press OK to save - EXIT to cancel"
msgstr "சேமிக்க சரி என்பதை அழுத்தவும் - ரத்து செய்ய வெளியேறவும்"

msgid "Press type for"
msgstr "வகையை அழுத்தவும்"

msgid "Press type for button"
msgstr "பட்டனுக்கான வகையை அழுத்தவும்"

msgid "Professional screenshot tool"
msgstr "தொழில்முறை ஸ்கிரீன்ஷாட் கருவி"

msgid "Resolution"
msgstr "தீர்மானம்"

msgid "Save path (requires restart)"
msgstr "பாதையைச் சேமி (மறுதொடக்கம் தேவை)"

msgid "Save screenshots even if frame is frozen."
msgstr "சட்டகம் உறைந்திருந்தாலும் ஸ்கிரீன்ஷாட்களைச் சேமிக்கவும்."

msgid "Screenshot saved successfully!"
msgstr "ஸ்கிரீன்ஷாட் வெற்றிகரமாக சேமிக்கப்பட்டது!"

msgid "Select screenshot button"
msgstr "ஸ்கிரீன்ஷாட் பொத்தானைத் தேர்ந்தெடுக்கவும்"

msgid "Select the image format for screenshots."
msgstr "ஸ்கிரீன் ஷாட்களுக்கான பட வடிவமைப்பைத் தேர்ந்தெடுக்கவும்."

msgid "Select the resolution for screenshots."
msgstr "திரைக்காட்சிகளுக்கான தெளிவுத்திறனைத் தேர்ந்தெடுக்கவும்."

msgid "Set press type for button instead of long press."
msgstr "நீண்ட நேரம் அழுத்துவதற்குப் பதிலாக பட்டனுக்கான அழுத்த வகையை அமைக்கவும்."

msgid "Settings"
msgstr "அமைப்புகள்"

msgid "Slower but smoother image resizing."
msgstr "மெதுவான ஆனால் மென்மையான படத்தின் மறுஅளவாக்கம்."

msgid "Temporary"
msgstr "தற்காலிகமானது"

msgid "Time to display messages on screen."
msgstr "திரையில் செய்திகளைக் காண்பிக்கும் நேரம்."

msgid "USB Drive"
msgstr "USB டிரைவ்"

msgid "Unknown"
msgstr "தெரியவில்லை"

msgid "Use bicubic resize"
msgstr "பைகுபிக் அளவைப் பயன்படுத்தவும்"

msgid "Use bicubic resize (slower, but smoother image)"
msgstr "பைகுபிக் அளவைப் பயன்படுத்தவும் (மெதுவான, ஆனால் மென்மையான படம்)"

msgid "Video Only"
msgstr "வீடியோ மட்டும்"

msgid "View captured screenshots"
msgstr "கைப்பற்றப்பட்ட ஸ்கிரீன் ஷாட்களைக் காண்க"

msgid "Web capture failed: Grab not available"
msgstr "வலைப் பிடிப்பு தோல்வி: கிராப் கிடைக்கவில்லை"

msgid "long ' can be used."
msgstr "நீண்ட ' பயன்படுத்த முடியும்."

msgid "long:"
msgstr "நீண்ட:"

msgid "no message"
msgstr "செய்தி இல்லை"

msgid "no timeout"
msgstr "காலக்கெடு இல்லை"

msgid "please wait, loading picture..."
msgstr "தயவுசெய்து காத்திருக்கவும், படத்தை ஏற்றுகிறது..."
