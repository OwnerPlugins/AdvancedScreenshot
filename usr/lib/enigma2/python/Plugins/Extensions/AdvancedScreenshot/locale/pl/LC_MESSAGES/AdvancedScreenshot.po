msgstr "Dodaj letterbox, jeśli źródło ma format 16:9."

msgid "Advanced Screenshot"
msgstr "Zaawansowany zrzut ekranu"

msgid "Advanced Screenshot Gallery"
msgstr "Zaawansowana galeria zrzutów ekranu"

msgid "Advanced Screenshot Setup"
msgstr "Zaawansowana konfiguracja zrzutów ekranu"

msgid "Always output 4:3 image"
msgstr "Zawsze wysyłaj obraz w formacie 4:3"

msgid "Always output 4:3 image (adds letterbox if source is 16:9)"
msgstr "Zawsze wysyłaj obraz w formacie 4:3 (dodaje letterbox, jeśli źródło ma format 16:9)"

