msgid "long ' can be used."
msgstr "लामो' प्रयोग गर्न सकिन्छ।"

msgid "long:"
msgstr "लामो:"

msgid "no message"
msgstr "कुनै सन्देश छैन"

msgid "no timeout"
msgstr "समय समाप्त छैन"

msgid "please wait, loading picture..."
msgstr "कृपया पर्खनुहोस्, फोटो लोड गर्दै..."
