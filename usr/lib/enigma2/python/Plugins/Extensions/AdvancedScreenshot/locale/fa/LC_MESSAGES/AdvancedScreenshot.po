msgstr "EPG"

msgid "Press OK to save - EXIT to cancel"
msgstr "برای ذخیره، OK را فشار دهید - برای لغو، EXIT را فشار دهید"

msgid "Press type for"
msgstr "نوع برای را فشار دهید"

msgid "Press type for button"
msgstr "دکمه type for را فشار دهید"

msgid "Professional screenshot tool"
msgstr "ابزار حرفه ای اسکرین شات"

msgid "Resolution"
msgstr "قطعنامه"

