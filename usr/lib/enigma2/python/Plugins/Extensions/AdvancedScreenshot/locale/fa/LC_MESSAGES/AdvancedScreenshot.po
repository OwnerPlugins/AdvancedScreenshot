msgid "Long press must be used for this button."
msgstr "برای این دکمه باید از فشار طولانی استفاده شود."

msgid "Long press required for"
msgstr "فشار طولانی برای"

msgid "Long press required for button"
msgstr "فشار طولانی برای دکمه مورد نیاز است"

msgid "Message timeout (seconds)"
msgstr "پایان زمان پیام (ثانیه)"

msgid "Network mount"
msgstr "نصب شبکه"

msgid "OSD + Video"
msgstr "OSD + ویدئو"

msgid "OSD Only"
msgstr "OSD فقط"

