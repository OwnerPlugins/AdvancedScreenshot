msgstr "ذخیره مسیر (نیاز به راه اندازی مجدد)"

msgid "Save screenshots even if frame is frozen."
msgstr "حتی اگر فریم ثابت باشد، اسکرین شات ها را ذخیره کنید."

msgid "Screenshot saved successfully!"
msgstr "عکس صفحه با موفقیت ذخیره شد!"

msgid "Select screenshot button"
msgstr "دکمه اسکرین شات را انتخاب کنید"

msgid "Select the image format for screenshots."
msgstr "فرمت تصویر را برای اسکرین شات ها انتخاب کنید."

msgid "Select the resolution for screenshots."
msgstr "وضوح تصویر را انتخاب کنید."

msgid "Set press type for button instead of long press."
msgstr "به جای فشار طولانی، نوع فشار را برای دکمه تنظیم کنید."

msgid "Settings"
msgstr "تنظیمات"

msgid "Slower but smoother image resizing."
msgstr "تغییر اندازه تصویر آهسته تر اما نرم تر."

msgid "Temporary"
msgstr "موقت"

msgid "Time to display messages on screen."
msgstr "زمان نمایش پیام ها بر روی صفحه نمایش"

msgid "USB Drive"
msgstr "درایو USB"

msgid "Unknown"
msgstr "ناشناس"

msgid "Use bicubic resize"
msgstr "از تغییر اندازه دو مکعبی استفاده کنید"

msgid "Use bicubic resize (slower, but smoother image)"
msgstr "از تغییر اندازه دو مکعبی استفاده کنید (تصویر کندتر، اما صاف تر)"

msgid "Video Only"
msgstr "فقط ویدیو"

msgid "View captured screenshots"
msgstr "مشاهده اسکرین شات های گرفته شده"

msgid "Web capture failed: Grab not available"
msgstr "ضبط وب ناموفق بود: گرفتن در دسترس نیست"

msgid "long ' can be used."
msgstr "طولانی ' را می توان استفاده کرد."

msgid "long:"
msgstr "طولانی:"

msgid "no message"
msgstr "بدون پیام"

msgid "no timeout"
msgstr "بدون تایم اوت"

msgid "please wait, loading picture..."
msgstr "لطفا صبر کنید، در حال بارگذاری تصویر..."

