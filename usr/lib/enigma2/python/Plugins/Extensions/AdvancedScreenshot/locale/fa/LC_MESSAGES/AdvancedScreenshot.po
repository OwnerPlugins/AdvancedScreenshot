msgid "' button instead of '"
msgstr "دکمه "به جای""

msgid "Add -n option to force no stretching."
msgstr "گزینه -n را برای عدم کشش مجبور کنید."

msgid "Add letterbox if source is 16:9."
msgstr "اگر منبع 16:9 است صندوق نامه را اضافه کنید."

msgid "Advanced Screenshot"
msgstr "اسکرین شات پیشرفته"

msgid "Advanced Screenshot Gallery"
msgstr "گالری اسکرین شات پیشرفته"

msgid "Advanced Screenshot Setup"
msgstr "تنظیم اسکرین شات پیشرفته"

msgid "Always output 4:3 image"
msgstr "همیشه تصویر 4:3 خروجی بگیرید"

msgid "Always output 4:3 image (adds letterbox if source is 16:9)"
msgstr "همیشه تصویر 4:3 خروجی بگیرید (اگر منبع 16:9 باشد صندوق نامه را اضافه می کند)"

msgid "Always save screenshots"
msgstr "همیشه اسکرین شات ها را ذخیره کنید"

msgid "Are you sure you want to delete this screenshot?"
msgstr "آیا مطمئن هستید که می خواهید این اسکرین شات را حذف کنید؟"

msgid "BMP"
msgstr ""

msgid "Choose which button triggers screenshot."
msgstr "انتخاب کنید کدام دکمه عکس صفحه نمایش را فعال کند."

msgid "Default Resolution"
msgstr "وضوح پیش فرض"

msgid "Delete failed:"
msgstr "حذف نشد:"

msgid "Enable or disable the Advanced Screenshot plugin."
msgstr "افزونه Advanced Screenshot را فعال یا غیرفعال کنید."

msgid "Enable plugin"
msgstr "افزونه را فعال کنید"

msgid "Error during capture:\n"
msgstr "خطا در هنگام ضبط:\n"

msgid "Error loading gallery:"
msgstr "خطا در بارگیری گالری:"

msgid "Fix aspect ratio"
msgstr "نسبت تصویر را اصلاح کنید"

msgid "Fix aspect ratio (adds -n to force no stretching)"
msgstr "نسبت تصویر را اصلاح کنید (n- را اضافه می کند تا بدون کشش مجبور شود)"

msgid "Folder where screenshots are saved."
msgstr "پوشه ای که اسکرین شات ها در آن ذخیره می شوند."

msgid "Freeze frame preview"
msgstr "فریز کردن پیش نمایش فریم"

msgid "Freeze the frame preview when taking screenshot."
msgstr "هنگام گرفتن اسکرین شات، پیش نمایش فریم را ثابت کنید."

