msgid "' button instead of '"
msgstr "በምትኩ 'አዝራር'"

msgid "Add -n option to force no stretching."
msgstr "አክል -n አማራጭ እንዳይዘረጋ ለማስገደድ።"

msgid "Add letterbox if source is 16:9."
msgstr "ምንጩ 16፡9 ከሆነ የደብዳቤ ሳጥን ያክሉ።"

msgid "Advanced Screenshot"
msgstr "የላቀ ቅጽበታዊ ገጽ እይታ"

msgid "Advanced Screenshot Gallery"
msgstr "የላቀ የቅጽበታዊ ገጽ እይታ ጋለሪ"

msgid "Advanced Screenshot Setup"
msgstr "የላቀ ቅጽበታዊ ገጽ እይታ ማዋቀር"

msgid "Always output 4:3 image"
msgstr "ሁልጊዜ 4፡3 ምስል አውጣ"

msgid "Always output 4:3 image (adds letterbox if source is 16:9)"
msgstr "ሁልጊዜ 4፡3 ምስል አውጣ (ምንጭ 16፡9 ከሆነ የደብዳቤ ሳጥን ይጨምራል)"

msgid "Always save screenshots"
msgstr "ሁልጊዜ ቅጽበታዊ ገጽ እይታዎችን ያስቀምጡ"

msgid "Are you sure you want to delete this screenshot?"
msgstr "እርግጠኛ ነዎት ይህን ቅጽበታዊ ገጽ እይታ መሰረዝ ይፈልጋሉ?"

msgid "BMP"
msgstr "ቢኤምፒ"

msgid "Choose which button triggers screenshot."
msgstr "ቅጽበታዊ ገጽ እይታን የሚቀሰቅሰው የትኛው አዝራር ይምረጡ።"

msgid "Default Resolution"
msgstr "ነባሪ ጥራት"

msgid "Delete failed:"
msgstr "መሰረዝ አልተሳካም፦"

msgid "Enable or disable the Advanced Screenshot plugin."
msgstr "የላቀ ቅጽበታዊ ገጽ እይታ ተሰኪን አንቃ ወይም አሰናክል።"

msgid "Enable plugin"
msgstr "ተሰኪን አንቃ"

msgid "Error during capture:\n"
msgstr "በመያዝ ጊዜ ስህተት፡\n"

msgid "Error loading gallery:"
msgstr "ማዕከለ-ስዕላትን መጫን ላይ ስህተት"

msgid "Fix aspect ratio"
msgstr "ምጥጥነ ገጽታን አስተካክል።"

msgid "Fix aspect ratio (adds -n to force no stretching)"
msgstr "ምጥጥነ ገጽታን አስተካክል (ምንም መዘርጋትን ለማስገደድ -n ይጨምራል)"

msgid "Folder where screenshots are saved."
msgstr "ቅጽበታዊ ገጽ እይታዎች የሚቀመጡበት አቃፊ።"

msgid "Freeze frame preview"
msgstr "የፍሬም ቅድመ እይታን አሰር"

msgid "Freeze the frame preview when taking screenshot."
msgstr "ቅጽበታዊ ገጽ እይታን ሲያነሱ የፍሬም ቅድመ-እይታን ያቁሙ።"

msgid "Hard Disk"
msgstr "ሃርድ ዲስክ"

msgid "Image format"
msgstr "የምስል ቅርጸት"

msgid "JPEG 100%"
msgstr ""

msgid "JPEG 60%"
msgstr ""

msgid "JPEG 80%"
msgstr ""

msgid "JPEG 90%"
msgstr ""

msgid "Long press must be used for this button."
msgstr "ለዚህ አዝራር በረጅሙ ተጭኖ መጠቀም አለበት።"

msgid "Long press required for"
msgstr "ለረጅም ጊዜ መጫን ያስፈልጋል"

msgid "Long press required for button"
msgstr "ለአዝራር በረጅሙ ተጫን"

msgid "Message timeout (seconds)"
msgstr "የመልእክት ጊዜ ማብቂያ (ሰከንዶች)"

msgid "Network mount"
msgstr "የአውታረ መረብ ጭነት"

msgid "OSD + Video"
msgstr "OSD + ቪዲዮ"

msgid "OSD Only"
msgstr "OSD ብቻ"

msgid "PNG"
msgstr ""

msgid "Press OK to save - EXIT to cancel"
msgstr "ለማስቀመጥ እሺን ይጫኑ - ለመሰረዝ ውጣ"

msgid "Press type for"
msgstr "ለ የሚለውን አይነት ይጫኑ"

msgid "Press type for button"
msgstr "ለ አዝራር አይነትን ተጫን"

msgid "Professional screenshot tool"
msgstr "የባለሙያ ቅጽበታዊ ገጽ እይታ መሣሪያ"

msgid "Resolution"
msgstr "ጥራት"

msgid "Save path (requires restart)"
msgstr "ዱካ አስቀምጥ (ዳግም ማስጀመር ያስፈልገዋል)"

msgid "Save screenshots even if frame is frozen."
msgstr "ክፈፉ ቢቀዘቅዝም ቅጽበታዊ ገጽ እይታዎችን ያስቀምጡ።"

msgid "Screenshot saved successfully!"
msgstr "ቅጽበታዊ ገጽ እይታ በተሳካ ሁኔታ ተቀምጧል!"

msgid "Select screenshot button"
msgstr "የቅጽበታዊ ገጽ እይታ ቁልፍን ይምረጡ"

msgid "Select the image format for screenshots."
msgstr "ለቅጽበታዊ ገጽ እይታዎች የምስል ቅርጸቱን ይምረጡ።"

msgid "Select the resolution for screenshots."
msgstr "ለቅጽበታዊ ገጽ እይታዎች ጥራትን ይምረጡ።"

msgid "Set press type for button instead of long press."
msgstr "በረጅሙ ከመጫን ይልቅ የፕሬስ አይነትን ለአዝራር ያዘጋጁ።"

msgid "Settings"
msgstr "ቅንብሮች"

msgid "Slower but smoother image resizing."
msgstr "ቀርፋፋ ግን ለስላሳ የምስል መጠን መቀየር።"

msgid "Temporary"
msgstr "ጊዜያዊ"

msgid "Time to display messages on screen."
msgstr "በስክሪኑ ላይ መልዕክቶችን ለማሳየት ጊዜው አሁን ነው።"

msgid "USB Drive"
msgstr "የዩኤስቢ ድራይቭ"

msgid "Unknown"
msgstr "ያልታወቀ"

msgid "Use bicubic resize"
msgstr "የቢኩቢክ መጠንን ተጠቀም"

msgid "Use bicubic resize (slower, but smoother image)"
msgstr "የቢኩቢክ መጠንን ተጠቀም (ቀስ ያለ፣ ግን ለስላሳ ምስል)"

msgid "Video Only"
msgstr "ቪዲዮ ብቻ"

msgid "View captured screenshots"
msgstr "የተያዙ ቅጽበታዊ ገጽ እይታዎችን ይመልከቱ"

msgid "Web capture failed: Grab not available"
msgstr "የድር ቀረጻ አልተሳካም፡ ያዝ አይገኝም"

msgid "long ' can be used."
msgstr "ረጅም" መጠቀም ይቻላል."

msgid "long:"
msgstr "ረጅም፡-"

msgid "no message"
msgstr "መልእክት የለም።"

msgid "no timeout"
msgstr "ምንም ጊዜ ማብቂያ የለም"

msgid "please wait, loading picture..."
msgstr "እባክህ ቆይ ፎቶ በመጫን ላይ..."
