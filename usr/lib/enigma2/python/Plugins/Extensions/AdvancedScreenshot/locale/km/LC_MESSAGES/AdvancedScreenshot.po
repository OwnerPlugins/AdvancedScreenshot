msgid "' button instead of '"
msgstr "'ប៊ូតុងជំនួសឱ្យ'"

msgid "Add -n option to force no stretching."
msgstr "បន្ថែម -n ជម្រើសដើម្បីបង្ខំមិនលាតសន្ធឹង។"

msgid "Add letterbox if source is 16:9."
msgstr "បន្ថែមប្រអប់សំបុត្រប្រសិនបើប្រភពគឺ 16:9 ។"

msgid "Advanced Screenshot"
msgstr "រូបថតអេក្រង់កម្រិតខ្ពស់"

msgid "Advanced Screenshot Gallery"
msgstr "វិចិត្រសាលរូបថតអេក្រង់កម្រិតខ្ពស់"

msgid "Advanced Screenshot Setup"
msgstr "ការដំឡើងរូបថតអេក្រង់កម្រិតខ្ពស់"

msgid "Always output 4:3 image"
msgstr "បង្ហាញរូបភាព 4:3 ជានិច្ច"

msgid "Always output 4:3 image (adds letterbox if source is 16:9)"
msgstr "បង្ហាញរូបភាព 4:3 ជានិច្ច (បន្ថែមប្រអប់សំបុត្រប្រសិនបើប្រភពគឺ 16:9)"

msgid "Always save screenshots"
msgstr "រក្សាទុករូបថតអេក្រង់ជានិច្ច"

msgid "Are you sure you want to delete this screenshot?"
msgstr "តើអ្នកប្រាកដថាចង់លុបរូបថតអេក្រង់នេះទេ?"

msgid "BMP"
msgstr ""

msgid "Choose which button triggers screenshot."
msgstr "ជ្រើសរើស​ប៊ូតុង​មួយ​ណា​ដែល​បើក​អេក្រង់។"

msgid "Default Resolution"
msgstr "ដំណោះស្រាយលំនាំដើម"

msgid "Delete failed:"
msgstr "ការលុបបរាជ័យ៖"

msgid "Enable or disable the Advanced Screenshot plugin."
msgstr "បើក ឬបិទកម្មវិធីជំនួយរូបថតអេក្រង់កម្រិតខ្ពស់។"

msgid "Enable plugin"
msgstr "បើកកម្មវិធីជំនួយ"

msgid "Error during capture:\n"
msgstr "កំហុសអំឡុងពេលថត៖\n"

msgid "Error loading gallery:"
msgstr "មាន​បញ្ហា​ក្នុង​ការ​ផ្ទុក​វិចិត្រសាល៖"

msgid "Fix aspect ratio"
msgstr "ជួសជុលសមាមាត្រ"

msgid "Fix aspect ratio (adds -n to force no stretching)"
msgstr "ជួសជុលសមាមាត្រ (បន្ថែម -n ដើម្បីបង្ខំកុំឱ្យលាតសន្ធឹង)"

msgid "Folder where screenshots are saved."
msgstr "ថតឯកសារដែលរូបថតអេក្រង់ត្រូវបានរក្សាទុក។"

msgid "Freeze frame preview"
msgstr "ការមើលជាមុននៃស៊ុមបង្កក"

msgid "Freeze the frame preview when taking screenshot."
msgstr "បង្កកការមើលស៊ុមជាមុន នៅពេលថតអេក្រង់។"

msgid "Hard Disk"
msgstr "ថាសរឹង"

msgid "Image format"
msgstr "ទម្រង់រូបភាព"

msgid "JPEG 100%"
msgstr ""

msgid "JPEG 60%"
msgstr ""

msgid "JPEG 80%"
msgstr ""

msgid "JPEG 90%"
msgstr ""

msgid "Long press must be used for this button."
msgstr "ការចុចឱ្យយូរត្រូវតែប្រើសម្រាប់ប៊ូតុងនេះ។"

msgid "Long press required for"
msgstr "ត្រូវការចុចឱ្យយូរ"

msgid "Long press required for button"
msgstr "តម្រូវឱ្យចុចឱ្យយូរសម្រាប់ប៊ូតុង"

msgid "Message timeout (seconds)"
msgstr "អស់ពេលសារ (វិនាទី)"

msgid "Network mount"
msgstr "បណ្តាញភ្ជាប់"

msgid "OSD + Video"
msgstr "OSD + វីដេអូ"

msgid "OSD Only"
msgstr "OSD តែប៉ុណ្ណោះ"

msgid "PNG"
msgstr ""

msgid "Press OK to save - EXIT to cancel"
msgstr "ចុចយល់ព្រមដើម្បីរក្សាទុក - ចេញដើម្បីបោះបង់"

msgid "Press type for"
msgstr "ចុចប្រភេទសម្រាប់"

msgid "Press type for button"
msgstr "ចុចប្រភេទសម្រាប់ប៊ូតុង"

msgid "Professional screenshot tool"
msgstr "ឧបករណ៍រូបថតអេក្រង់ដែលមានជំនាញវិជ្ជាជីវៈ"

msgid "Resolution"
msgstr "ដំណោះស្រាយ"

msgid "Save path (requires restart)"
msgstr "រក្សាទុកផ្លូវ (ទាមទារការចាប់ផ្តើមឡើងវិញ)"

msgid "Save screenshots even if frame is frozen."
msgstr "រក្សាទុករូបថតអេក្រង់ទោះបីជាស៊ុមត្រូវបានបង្កកក៏ដោយ។"

msgid "Screenshot saved successfully!"
msgstr "រូបថតអេក្រង់ត្រូវបានរក្សាទុកដោយជោគជ័យ!"

msgid "Select screenshot button"
msgstr "ជ្រើសរើសប៊ូតុងរូបថតអេក្រង់"

msgid "Select the image format for screenshots."
msgstr "ជ្រើសរើសទម្រង់រូបភាពសម្រាប់រូបថតអេក្រង់។"

msgid "Select the resolution for screenshots."
msgstr "ជ្រើសរើសគុណភាពបង្ហាញសម្រាប់រូបថតអេក្រង់។"

msgid "Set press type for button instead of long press."
msgstr "កំណត់ប្រភេទចុចសម្រាប់ប៊ូតុងជំនួសឱ្យការចុចយូរ។"

msgid "Settings"
msgstr "ការកំណត់"

msgid "Slower but smoother image resizing."
msgstr "ផ្លាស់ប្តូរទំហំរូបភាពយឺត ប៉ុន្តែរលោងជាងមុន។"

msgid "Temporary"
msgstr "បណ្ដោះអាសន្ន"

msgid "Time to display messages on screen."
msgstr "ដល់ពេលបង្ហាញសារនៅលើអេក្រង់។"

msgid "USB Drive"
msgstr "ដ្រាយ USB"

msgid "Unknown"
msgstr "មិនស្គាល់"

msgid "Use bicubic resize"
msgstr "ប្រើការប្តូរទំហំប៊ីប៊ីប៊ីក"

msgid "Use bicubic resize (slower, but smoother image)"
msgstr "ប្រើការផ្លាស់ប្តូរទំហំប៊ីប៊ីប៊ីក (រូបភាពយឺត ប៉ុន្តែរលោងជាង)"

msgid "Video Only"
msgstr "វីដេអូតែប៉ុណ្ណោះ"

msgid "View captured screenshots"
msgstr "មើលរូបថតអេក្រង់ដែលបានថត"

msgid "Web capture failed: Grab not available"
msgstr "ការចាប់យកគេហទំព័របានបរាជ័យ៖ Grab មិនមានទេ។"

msgid "long ' can be used."
msgstr "អាចប្រើប្រាស់បានយូរ។"

msgid "long:"
msgstr "វែង៖"

msgid "no message"
msgstr "គ្មានសារ"

msgid "no timeout"
msgstr "មិនអស់ពេលទេ។"

msgid "please wait, loading picture..."
msgstr "សូមរង់ចាំ ផ្ទុករូបភាព..."
