msgid "' button instead of '"
msgstr "ปุ่ม ' แทน '"

msgid "Add -n option to force no stretching."
msgstr "เพิ่มตัวเลือก -n เพื่อไม่ให้ยืดออก"

msgid "Add letterbox if source is 16:9."
msgstr "เพิ่มกล่องจดหมายหากแหล่งที่มาเป็น 16:9"

msgid "Advanced Screenshot"
msgstr "ภาพหน้าจอขั้นสูง"

msgid "Advanced Screenshot Gallery"
msgstr "แกลเลอรี่ภาพหน้าจอขั้นสูง"

msgid "Advanced Screenshot Setup"
msgstr "การตั้งค่าภาพหน้าจอขั้นสูง"

msgid "Always output 4:3 image"
msgstr "เอาต์พุตภาพ 4:3 เสมอ"

msgid "Always output 4:3 image (adds letterbox if source is 16:9)"
msgstr "เอาต์พุตรูปภาพ 4:3 เสมอ (เพิ่มกล่องจดหมายหากต้นฉบับเป็น 16:9)"

msgid "Always save screenshots"
msgstr "บันทึกภาพหน้าจอเสมอ"

msgid "Are you sure you want to delete this screenshot?"
msgstr "คุณแน่ใจหรือไม่ว่าต้องการลบภาพหน้าจอนี้"

msgid "BMP"
msgstr "บีเอ็มพี"

