msgstr "การติดตั้งเครือข่าย"

msgid "OSD + Video"
msgstr "OSD + วิดีโอ"

msgid "OSD Only"
msgstr "OSD เท่านั้น"

msgid "PNG"
msgstr ""

msgid "Press OK to save - EXIT to cancel"
msgstr "กด OK เพื่อบันทึก - EXIT เพื่อยกเลิก"

msgid "Press type for"
msgstr "กดพิมพ์เพื่อ"

msgid "Press type for button"
msgstr "กดปุ่มประเภท"

