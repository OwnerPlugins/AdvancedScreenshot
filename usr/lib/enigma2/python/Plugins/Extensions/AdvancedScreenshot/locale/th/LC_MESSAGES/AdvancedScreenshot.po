msgstr "เลือกปุ่มที่จะเรียกใช้ภาพหน้าจอ"

msgid "Default Resolution"
msgstr "ความละเอียดเริ่มต้น"

msgid "Delete failed:"
msgstr "ลบไม่สำเร็จ:"

msgid "Enable or disable the Advanced Screenshot plugin."
msgstr "เปิดหรือปิดใช้งานปลั๊กอินภาพหน้าจอขั้นสูง"

msgid "Enable plugin"
msgstr "เปิดใช้งานปลั๊กอิน"

msgid "Error during capture:\n"
msgstr "เกิดข้อผิดพลาดระหว่างการจับภาพ:\n"

msgid "Error loading gallery:"
msgstr "เกิดข้อผิดพลาดในการโหลดแกลเลอรี:"

msgid "Fix aspect ratio"
msgstr "แก้ไขอัตราส่วนภาพ"

msgid "Fix aspect ratio (adds -n to force no stretching)"
msgstr "แก้ไขอัตราส่วนภาพ (เพิ่ม -n เพื่อบังคับให้ไม่ยืดออก)"

msgid "Folder where screenshots are saved."
msgstr "โฟลเดอร์ที่บันทึกภาพหน้าจอ"

msgid "Freeze frame preview"
msgstr "แสดงตัวอย่างเฟรมตรึง"

msgid "Freeze the frame preview when taking screenshot."
msgstr "หยุดการแสดงตัวอย่างเฟรมเมื่อถ่ายภาพหน้าจอ"

msgid "Hard Disk"
msgstr "ฮาร์ดดิสก์"

msgid "Image format"
msgstr "รูปแบบภาพ"

msgid "JPEG 100%"
msgstr "เจเพ็ก 100%"

msgid "JPEG 60%"
msgstr "เจเพ็ก 60%"

msgid "JPEG 80%"
msgstr "เจเพ็ก 80%"

msgid "JPEG 90%"
msgstr "เจเพ็ก 90%"

msgid "Long press must be used for this button."
