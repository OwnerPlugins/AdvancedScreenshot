msgid "Screenshot saved successfully!"
msgstr "บันทึกภาพหน้าจอเรียบร้อยแล้ว!"

msgid "Select screenshot button"
msgstr "เลือกปุ่มภาพหน้าจอ"

msgid "Select the image format for screenshots."
msgstr "เลือกรูปแบบภาพสำหรับภาพหน้าจอ"

msgid "Select the resolution for screenshots."
msgstr "เลือกความละเอียดสำหรับภาพหน้าจอ"

msgid "Set press type for button instead of long press."
msgstr "ตั้งค่าประเภทการกดปุ่มแทนการกดแบบยาว"

msgid "Settings"
msgstr "การตั้งค่า"

msgid "Slower but smoother image resizing."
msgstr "การปรับขนาดภาพที่ช้ากว่าแต่นุ่มนวลกว่า"

msgid "Temporary"
msgstr "ชั่วคราว"

msgid "Time to display messages on screen."
msgstr "เวลาในการแสดงข้อความบนหน้าจอ"

msgid "USB Drive"
msgstr "ไดรฟ์ USB"

msgid "Unknown"
msgstr "ไม่ทราบ"

msgid "Use bicubic resize"
msgstr "ใช้การปรับขนาดแบบไบคิวบิก"

msgid "Use bicubic resize (slower, but smoother image)"
msgstr "ใช้การปรับขนาด bicubic (ภาพที่ช้ากว่า แต่นุ่มนวลกว่า)"

msgid "Video Only"
msgstr "วิดีโอเท่านั้น"

msgid "View captured screenshots"
msgstr "ดูภาพหน้าจอที่บันทึกไว้"

msgid "Web capture failed: Grab not available"
msgstr "การจับภาพเว็บล้มเหลว: Grab ไม่พร้อมใช้งาน"

msgid "long ' can be used."
msgstr "ยาว' ก็ใช้ได้"

msgid "long:"
msgstr "ยาว:"

msgid "no message"
msgstr "ไม่มีข้อความ"

msgid "no timeout"
msgstr "ไม่มีการหมดเวลา"

msgid "please wait, loading picture..."
msgstr "กรุณารอสักครู่ กำลังโหลดภาพ..."
