msgstr ""

msgid "no message"
msgstr "کوئی پیغام نہیں"

msgid "no timeout"
msgstr "کوئی ٹائم آؤٹ نہیں"

msgid "please wait, loading picture..."
msgstr "براہ کرم انتظار کریں، تصویر لوڈ ہو رہی ہے..."
