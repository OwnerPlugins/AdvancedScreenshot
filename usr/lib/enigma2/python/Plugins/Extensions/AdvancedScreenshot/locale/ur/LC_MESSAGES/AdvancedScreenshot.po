msgid "' button instead of '"
msgstr "'بجائے' بٹن"

msgid "Add -n option to force no stretching."
msgstr "زبردستی نہ کھینچنے کے لیے -n آپشن شامل کریں۔"

msgid "Add letterbox if source is 16:9."
msgstr "اگر ماخذ 16:9 ہے تو لیٹر باکس شامل کریں۔"

msgid "Advanced Screenshot"
msgstr "اعلی درجے کا اسکرین شاٹ"

msgid "Advanced Screenshot Gallery"
msgstr "اعلی درجے کی اسکرین شاٹ گیلری"

msgid "Advanced Screenshot Setup"
msgstr "اعلی درجے کی اسکرین شاٹ سیٹ اپ"

msgid "Always output 4:3 image"
msgstr "ہمیشہ 4:3 امیج کو آؤٹ پٹ کریں۔"

msgid "Always output 4:3 image (adds letterbox if source is 16:9)"
msgstr "ہمیشہ آؤٹ پٹ 4:3 امیج (اگر ماخذ 16:9 ہے تو لیٹر باکس شامل کرتا ہے)"

msgid "Always save screenshots"
msgstr "اسکرین شاٹس کو ہمیشہ محفوظ کریں۔"

msgid "Are you sure you want to delete this screenshot?"
msgstr "کیا آپ واقعی اس اسکرین شاٹ کو حذف کرنا چاہتے ہیں؟"

msgid "BMP"
msgstr "بی ایم پی"

msgid "Choose which button triggers screenshot."
msgstr "منتخب کریں کہ کون سا بٹن اسکرین شاٹ کو متحرک کرتا ہے۔"

msgid "Default Resolution"
msgstr "ڈیفالٹ ریزولوشن"

msgid "Delete failed:"
msgstr "حذف کرنے میں ناکام:"

msgid "Enable or disable the Advanced Screenshot plugin."
msgstr "ایڈوانسڈ اسکرین شاٹ پلگ ان کو فعال یا غیر فعال کریں۔"

msgid "Enable plugin"
msgstr "پلگ ان کو فعال کریں۔"

msgid "Error during capture:\n"
