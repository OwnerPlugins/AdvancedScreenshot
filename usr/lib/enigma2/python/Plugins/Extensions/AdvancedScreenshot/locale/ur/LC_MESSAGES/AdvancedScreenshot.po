msgstr "محفوظ کرنے کے لیے OK دبائیں - منسوخ کرنے کے لیے باہر نکلیں۔"

msgid "Press type for"
msgstr "کے لیے ٹائپ کریں۔"

msgid "Press type for button"
msgstr "بٹن کے لیے ٹائپ دبائیں"

