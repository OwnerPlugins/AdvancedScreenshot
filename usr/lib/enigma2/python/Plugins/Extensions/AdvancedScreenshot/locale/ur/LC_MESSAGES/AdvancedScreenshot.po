msgstr "پروفیشنل اسکرین شاٹ ٹول"

msgid "Resolution"
msgstr "قرارداد"

msgid "Save path (requires restart)"
msgstr "راستہ محفوظ کریں (دوبارہ شروع کرنے کی ضرورت ہے)"

msgid "Save screenshots even if frame is frozen."
msgstr "اسکرین شاٹس کو محفوظ کریں چاہے فریم منجمد ہو۔"

msgid "Screenshot saved successfully!"
msgstr "اسکرین شاٹ کامیابی کے ساتھ محفوظ ہو گیا!"

msgid "Select screenshot button"
msgstr "اسکرین شاٹ بٹن کو منتخب کریں۔"

msgid "Select the image format for screenshots."
msgstr "اسکرین شاٹس کے لیے تصویر کا فارمیٹ منتخب کریں۔"

msgid "Select the resolution for screenshots."
msgstr "اسکرین شاٹس کے لیے ریزولوشن منتخب کریں۔"

msgid "Set press type for button instead of long press."
msgstr "طویل دبانے کے بجائے بٹن کے لیے پریس ٹائپ سیٹ کریں۔"

msgid "Settings"
msgstr "ترتیبات"

msgid "Slower but smoother image resizing."
msgstr "آہستہ لیکن ہموار تصویر کا سائز تبدیل کرنا۔"

msgid "Temporary"
msgstr "عارضی"

msgid "Time to display messages on screen."
msgstr "اسکرین پر پیغامات ڈسپلے کرنے کا وقت۔"

msgid "USB Drive"
msgstr "USB ڈرائیو"

msgid "Unknown"
msgstr "نامعلوم"

msgid "Use bicubic resize"
msgstr "بائی کیوبک ری سائز استعمال کریں۔"

msgid "Use bicubic resize (slower, but smoother image)"
msgstr "بائی کیوبک سائز کا استعمال کریں (سست، لیکن ہموار تصویر)"

msgid "Video Only"
msgstr "صرف ویڈیو"

msgid "View captured screenshots"
msgstr "کیپچر کیے گئے اسکرین شاٹس دیکھیں"

msgid "Web capture failed: Grab not available"
msgstr "ویب کیپچر ناکام: گراب دستیاب نہیں ہے۔"

msgid "long ' can be used."
msgstr "طویل ' استعمال کیا جا سکتا ہے."

