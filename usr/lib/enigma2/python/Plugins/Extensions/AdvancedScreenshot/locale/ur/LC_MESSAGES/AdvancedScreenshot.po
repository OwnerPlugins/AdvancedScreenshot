msgstr ""

msgid "Long press must be used for this button."
msgstr "اس بٹن کے لیے طویل پریس کا استعمال کرنا چاہیے۔"

msgid "Long press required for"
msgstr "کے لیے طویل پریس کی ضرورت ہے۔"

msgid "Long press required for button"
msgstr "بٹن کے لیے دیر تک دبانے کی ضرورت ہے۔"

